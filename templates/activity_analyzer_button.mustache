{{!
    @template local_geniai/activity_analyzer_button

    Buttons injected into each course activity.

    Example context (json):
    {
        "cmid": 123
    }
}}
<div class="local-geniai-analysis-controls"
     data-cmid="{{{cmid}}}"
     role="group"
     aria-label="{{#str}}analysis_ai_block, local_geniai{{/str}}">

    <div class="local-geniai-analysis-controls-header">
        {{#pix}}icons/openai, local_geniai{{/pix}}
        <span>{{#str}}analysis_ai_block, local_geniai{{/str}}</span>
    </div>

    <div class="local-geniai-analysis-controls-actions">
        <button type="button"
                class="btn btn-sm btn-primary local-geniai-analyze-activity-btn"
                data-cmid="{{{cmid}}}">
            {{#pix}}i/search, core{{/pix}}
            <span>{{#str}}analyze_activity, local_geniai{{/str}}</span>
        </button>

        <button type="button"
                class="btn btn-sm btn-outline-info local-geniai-latest-analysis-btn d-none"
                data-cmid="{{{cmid}}}">
            {{#pix}}i/report, core{{/pix}}
            <span class="local-geniai-latest-analysis-status">
                {{#str}}analysis_latest, local_geniai{{/str}}
            </span>
        </button>
    </div>

    <span class="local-geniai-latest-analysis-summary small text-muted d-none"></span>
</div>
