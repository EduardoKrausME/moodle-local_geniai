{{!
    @template local_geniai/activity_analyzer_result

    Renders an analysis result returned by the external function.

    Example context (json):
    {
        "content_html": "<h3>Diagnóstico geral</h3><p>OK</p>",
        "status": "OK",
        "bloom_level": "compreender",
        "recommendations": ["Improve the objective wording"]
    }
}}
<div class="local-geniai-analysis-card">
    {{#model_warning}}
        <div class="alert alert-warning local-geniai-analysis-model-warning" role="alert">
            {{{model_warning}}}
        </div>
    {{/model_warning}}

    {{#status}}
        <div class="badge badge-info mb-2 local-geniai-analysis-status">{{status}}</div>
    {{/status}}
    {{#bloom_level}}
        <div class="badge badge-secondary mb-2 local-geniai-analysis-bloom">Bloom: {{bloom_level}}</div>
    {{/bloom_level}}

    {{#has_recommendations}}
        <div class="card mb-3 local-geniai-analysis-recommendations">
            <div class="card-body py-2">
                <strong>{{#str}}analysis_recommendations, local_geniai{{/str}}</strong>
                <ul class="mb-0 pl-3">
                    {{#recommendations}}
                        <li>{{.}}</li>
                    {{/recommendations}}
                </ul>
            </div>
        </div>
    {{/has_recommendations}}

    <div class="local-geniai-analysis-content">
        {{{content_html}}}
    </div>
</div>
